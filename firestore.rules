rules_version = '2';
// ⚠️⚠️ 공유 규칙 — 니가교수 앱 + 회사 워크스페이스 포털이 같은 Firebase 프로젝트(yourprofessor-94a2d)를 함께 씀.
// ⚠️ Firestore 규칙은 프로젝트당 "딱 1세트"뿐. 게시할 땐 반드시 아래 통합본 "전체"를 게시할 것!
//    - users 규칙만 게시 → 워크스페이스 포털 깨짐
//    - ws_* 규칙만 게시 → 앱 클라우드 동기화 깨짐 ("클라우드 연결 실패")  ← 2026-07-01 실제 발생
// ⚠️ 이 파일은 YouareProfessor 레포와 urp-workspace 레포에 "동일하게" 보관됨. 한쪽 고치면 다른 쪽도 맞출 것.
//
// 핵심: 앱 데이터는 users/{uid}/data 하위에 저장됨 → match는 반드시 /users/{uid}/{document=**} (하위 포함).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/ws_members/$(request.auth.token.email));
    }

    // 워크스페이스: 팀 제출 결과 — 로그인한 누구나 읽기, 본인만 쓰기 (isMember 우회)
    match /ws_team/{uid} {
      allow write: if signedIn() && request.auth.uid == uid;
      allow read:  if signedIn();
    }

    // 워크스페이스: 멤버 명단
    match /ws_members/{email} {
      allow read: if signedIn();
      allow write: if isMember() || request.auth.token.email == 'soomin020114@gmail.com';
    }

    // 니가교수 앱: 본인 데이터 (하위 컬렉션 data/ 까지 포함) — {document=**} 빠지면 동기화 거부됨
    match /users/{uid}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // MEUS 무로그인 그룹방(수련회 등): meus_rooms/{방}/members/{이름} = {name, code, ts}
    // 링크 소지자 누구나 읽기/제출(로그인 불필요). 필드·크기 엄격 제한, 삭제는 운영자 계정만.
    match /meus_rooms/{room}/members/{member} {
      allow read: if true;
      allow create, update: if
        request.resource.data.keys().hasOnly(['name', 'code', 'ts'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 40
        && request.resource.data.code is string
        && request.resource.data.code.size() >= 2
        && request.resource.data.code.size() <= 4000
        && request.resource.data.ts is number
        && member.size() <= 60;
      allow delete: if signedIn() && request.auth.token.email == 'soomin020114@gmail.com';
    }

    // MEUS 그룹방 이름표(meta/info {title}) — 누구나 읽기, 쓰기·삭제는 운영자 계정만
    match /meus_rooms/{room}/meta/{doc} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.token.email == 'soomin020114@gmail.com'
        && request.resource.data.keys().hasOnly(['title'])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 60;
      allow delete: if signedIn() && request.auth.token.email == 'soomin020114@gmail.com';
    }

    // MEUS 그룹방 등록부(부모 문서 {title, ts}) — 운영자 대시보드의 방 목록·생성·삭제용
    match /meus_rooms/{room} {
      allow read, write: if signedIn() && request.auth.token.email == 'soomin020114@gmail.com';
    }

    // MEUS 운영자: 모든 방의 제출을 한 번에 조회 (collectionGroup 'members') — 운영자 계정만.
    // 현재 'members' 서브컬렉션은 meus_rooms에서만 사용.
    match /{path=**}/members/{member} {
      allow read: if signedIn() && request.auth.token.email == 'soomin020114@gmail.com';
    }

    // 학원 관리자 명단: aca_admins/{code} = {uids: [관리자 uid, ...]} — 운영자가 콘솔에서 관리.
    // ⚠️ 이 규칙 게시 전에 학원 코드별 aca_admins 문서를 먼저 만들 것 — 없으면 그 학원의 연동 목록 조회가 거부됨.
    match /aca_admins/{code} {
      allow read, write: if signedIn() && request.auth.token.email == 'soomin020114@gmail.com';
    }

    // 니가교수 학원 연동: 학생이 옵트인으로 공유한 학습 신호 (aca_shared/{code}__{uid})
    // 쓰기: 본인(uid가 문서 id 끝과 일치 + 데이터의 uid 필드도 본인)만.
    // 읽기: 본인 문서 or aca_admins/{code} 명단의 관리자만. 관리자 조회는 반드시 where('code','==',코드) 필터 필요.
    match /aca_shared/{docId} {
      allow write: if signedIn()
        && request.resource.data.keys().hasOnly(['code', 'uid', 'name', 't', 'v', 'attempts', 'agg', 'misclex'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.code is string
        && request.resource.data.code.size() >= 2
        && request.resource.data.code.size() <= 80
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 80
        && request.resource.data.t is number
        && request.resource.data.v is number
        && request.resource.data.attempts is list
        && request.resource.data.attempts.size() <= 600
        && docId == request.resource.data.code + '__' + request.auth.uid;
      allow delete: if signedIn() && docId.matches('.*__' + request.auth.uid);
      allow read: if signedIn() && (
        docId.matches('.*__' + request.auth.uid)
        || get(/databases/$(database)/documents/aca_admins/$(resource.data.code)).data.uids.hasAny([request.auth.uid])
      );
    }

    // 워크스페이스 컬렉션(ws_*) — 멤버만 읽기/쓰기
    match /{coll}/{id} {
      allow read, write: if isMember() && coll.matches('ws_.*');
    }
  }
}
